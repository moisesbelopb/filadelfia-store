# ============================================================
# Casa de Filadélfia — variáveis de ambiente (exemplo)
# Copie para .env.local e preencha. NUNCA commite .env.local.
# Só NEXT_PUBLIC_* chega ao browser; o resto é server-only.
# ============================================================

# --- Supabase (público) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- ZeptoMail / Zoho (server-only) — e-mails de pedido ---
# Token: ZeptoMail > Mail Agents > Setup Info > "Send Mail Token"
# (o valor após "Zoho-enczapikey"; cole SÓ o token aqui).
ZEPTOMAIL_TOKEN=
# Remetente verificado no ZeptoMail (domínio verificado).
ZEPTOMAIL_FROM_EMAIL=
ZEPTOMAIL_FROM_NAME=Casa de Filadélfia
# Opcional: use a URL EU se sua conta for da região Europa.
# ZEPTOMAIL_API_URL=https://api.zeptomail.eu/v1.1/email

# --- Auth Google ---
# Client ID/Secret ficam no painel do Supabase (Auth > Providers > Google),
# não aqui. Configure a Redirect URL: <SITE_URL>/api/auth/callback

# --- Administrador nativo (bootstrap via `pnpm create-admin`) ---
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Casa de Filadélfia
